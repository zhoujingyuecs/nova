# nova 配置示例文件。
# 把这个文件复制成 .env，按需改值。
# 也可以用 python launcher.py 的"配置向导"来自动写。
#
# 加载顺序：os.environ > .env > 代码默认值

# ============================================================
# LLM 后端
# ============================================================
# "local"  → 本地 GGUF（需要显卡 + llama-cpp-python）
# "openai" → OpenAI 兼容的 HTTP 端点（DeepSeek / 通义 / Moonshot / ...）
NOVA_LLM_BACKEND=openai

# ------------------------------------------------------------
# 云端后端（OpenAI 兼容 HTTP）
# ------------------------------------------------------------
# 几个常见预设（取消注释你要用的那一组）：

# --- DeepSeek（推荐起步）---
NOVA_LLM_API_BASE=https://api.deepseek.com/v1
NOVA_LLM_API_MODEL=deepseek-chat
NOVA_LLM_API_KEY=

# --- 阿里云百炼（通义千问 OpenAI 兼容入口）---
# NOVA_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# NOVA_LLM_API_MODEL=qwen-plus
# NOVA_LLM_API_KEY=

# --- 火山方舟（豆包）---
# NOVA_LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# NOVA_LLM_API_MODEL=ep-2024xxxxxxx-xxxxx   # 这里要换成你方舟开通的具体推理接入点 ID
# NOVA_LLM_API_KEY=

# --- Moonshot (Kimi) ---
# NOVA_LLM_API_BASE=https://api.moonshot.cn/v1
# NOVA_LLM_API_MODEL=moonshot-v1-32k
# NOVA_LLM_API_KEY=

# --- 智谱 GLM ---
# NOVA_LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# NOVA_LLM_API_MODEL=glm-4-plus
# NOVA_LLM_API_KEY=

# --- SiliconFlow（聚合开源模型）---
# NOVA_LLM_API_BASE=https://api.siliconflow.cn/v1
# NOVA_LLM_API_MODEL=Qwen/Qwen2.5-72B-Instruct
# NOVA_LLM_API_KEY=

# --- OpenRouter ---
# NOVA_LLM_API_BASE=https://openrouter.ai/api/v1
# NOVA_LLM_API_MODEL=deepseek/deepseek-chat
# NOVA_LLM_API_KEY=

# --- OpenAI ---
# NOVA_LLM_API_BASE=https://api.openai.com/v1
# NOVA_LLM_API_MODEL=gpt-4o-mini
# NOVA_LLM_API_KEY=

# --- Anthropic Claude（OpenAI 兼容层）---
# NOVA_LLM_API_BASE=https://api.anthropic.com/v1/
# NOVA_LLM_API_MODEL=claude-sonnet-4-5
# NOVA_LLM_API_KEY=

# --- Ollama / vLLM / 本机自托管 ---
# NOVA_LLM_API_BASE=http://127.0.0.1:11434/v1
# NOVA_LLM_API_MODEL=qwen2.5:7b
# NOVA_LLM_API_KEY=ollama

# 网络重试 / 超时
NOVA_LLM_API_TIMEOUT=120
NOVA_LLM_API_RETRIES=2

# ------------------------------------------------------------
# 本地后端（llama_cpp）
# ------------------------------------------------------------
# 只有 NOVA_LLM_BACKEND=local 才用得到这些。
# NOVA_MODEL_PATH=/path/to/your/Qwen2.5-32B-Q4_K_M.gguf
# NOVA_N_CTX=65536
# NOVA_N_GPU_LAYERS=99      # 99 = 全上 GPU
# NOVA_FLASH_ATTN=true

# ============================================================
# 通用 LLM 采样参数（两个后端都用）
# ============================================================
NOVA_TEMPERATURE=0.6
NOVA_TOP_P=0.95
NOVA_MAX_TOKENS=4096

# ============================================================
# VM 那只手
# ============================================================
# 最简单：脑子和手同机，127.0.0.1:7100
# 跨机：换成 VM 的 IP，比如 http://192.168.122.102:7100
NOVA_VM_URL=http://127.0.0.1:7100
NOVA_VM_TOKEN=please-change-me-to-a-random-string

# ============================================================
# 缝隙场存档目录
# ============================================================
NOVA_FIELD_PATH=./data/field

# ============================================================
# nova 自己的工作区（VM 那台机器上的目录）
# ============================================================
NOVA_WORKSPACE_ROOT=~/nova_workspace

# ============================================================
# 嵌入器
# ============================================================
# 默认中文小模型（100MB，CPU 就够）
NOVA_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
NOVA_EMBEDDING_DEVICE=cpu

# ============================================================
# 对外网页 / 公开窗口
# ============================================================
NOVA_EXTERNAL_SITE=https://codeloop.cn
# local.py 默认连这个 page；改成你的 page 部署地址
NOVA_CLOUD_URL=http://127.0.0.1:8080
