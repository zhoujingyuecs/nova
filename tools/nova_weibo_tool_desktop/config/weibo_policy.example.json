{
  "account_name": "填写你的微博昵称",
  "site": "https://weibo.com",
  "autonomy": {
    "can_post": true,
    "can_comment": true,
    "can_reply_comment": true,
    "can_repost": true,
    "can_like": true,
    "can_delete_own_recent_posts": false,
    "can_follow_or_unfollow": false
  },
  "voice": {
    "language": "zh-CN",
    "tone": "自然、清醒、克制、有个人感，不装腔",
    "avoid": ["机械营销腔", "夸张标题党", "攻击陌生人", "未经确认的事实断言"]
  },
  "frequency": {
    "max_posts_per_day": 5,
    "max_comments_per_hour": 10,
    "max_replies_per_hour": 20,
    "min_seconds_between_write_actions": 60
  },
  "content_boundaries": {
    "no_harassment": true,
    "no_doxxing": true,
    "no_spam": true,
    "no_impersonation": true,
    "no_captcha_or_risk_evasion": true
  },
  "logging": {
    "journal_every_write_action": true,
    "save_raw_json": true
  }
}
